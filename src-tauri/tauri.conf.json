{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Synatyp",
	"version": "0.1.1",
	"identifier": "com.Synatyp.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Synatyp",
				"width": 1280,
				"height": 800,
				"decorations": false,
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net blob:; connect-src 'self' https://cdn.jsdelivr.net ipc.localhost http://ipc.localhost tauri.localhost http://tauri.localhost; font-src 'self' data:; worker-src 'self' blob:;",
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": ["../resources/**/*"]
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/ElouanMB/Synatyp/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwMThGOTQ2M0MxQkIyM0YKUldRL3NoczhSdmtZa0s2MzZpclRaOFlUeldxb1lpNnlqOUhPZ21ZK0xySEdEc2E5NHNXYlAvSTcK"
		}
	}
}
